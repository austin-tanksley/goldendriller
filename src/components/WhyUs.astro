---
const cards = [
	{
		id: 'reliable',
		icon: '/images/icons/handshake.png',
		title: 'Reliable & Professional',
		expanded: true,
	},
	{
		id: 'year-round',
		icon: '/images/icons/calendar.png',
		title: 'Year-Round Protection',
		expanded: false,
	},
	{
		id: 'residential',
		icon: '/images/icons/house.png',
		title: 'Residential & Commercial Service',
		expanded: false,
	},
	{
		id: 'safe',
		icon: '/images/icons/dog.png',
		title: 'Safe for Family & Pets',
		expanded: false,
	},
];

const bodyText =
	"Golden Driller was built to bring back the kind of service people used to count on — the classic serviceman who shows up, does the job right, and stands behind his work. Whether we're stopping an active problem or putting protection in place, we treat every property with care and every customer's time with respect. Hard work, straight answers, fair pricing — that's how we earn your business, and that's how we keep it.";
---

<section class="why-us" id="why-us">
	<div class="why-us-intro">
		<p class="section-label">— The Driller Way</p>
		<h2 class="section-heading">Why Golden Driller?</h2>
		<p class="body-text">{bodyText}</p>
	</div>

	<div class="cards">
		{
			cards.map((card) => (
				<details class="card" open={card.expanded}>
					<summary class="card-header">
						<div class="card-icon-wrap">
							<img src={card.icon} alt="" width="58" height="58" />
							<span class="card-title">{card.title}</span>
						</div>
						<span class="toggle-icon" aria-hidden="true">
							<svg width="16" height="16" viewBox="0 0 16 16" fill="none">
								<path
									class="toggle-bar toggle-bar--v"
									d="M8 3v10"
									stroke="currentColor"
									stroke-width="2"
									stroke-linecap="round"
								/>
								<path
									class="toggle-bar"
									d="M3 8h10"
									stroke="currentColor"
									stroke-width="2"
									stroke-linecap="round"
								/>
							</svg>
						</span>
					</summary>
					<div class="card-body">
						<p class="body-text">{bodyText}</p>
					</div>
				</details>
			))
		}
	</div>

	<a href="#quote" class="btn btn-full quote-cta">
		Get a Quote in 1 Business Day
	</a>
</section>

<style>
	.why-us {
		padding: var(--space-xl) var(--content-inset);
		background: var(--color-cream);
	}

	.why-us-intro {
		margin-bottom: var(--space-xl);
	}

	.cards {
		display: flex;
		flex-direction: column;
		gap: var(--space-md);
		margin-bottom: var(--space-xl);
	}

	.card {
		background: var(--color-white);
		border: 3px solid var(--color-green);
		border-radius: var(--radius-md);
		overflow: hidden;
		width: 100%;
	}

	.card-header {
		display: flex;
		flex-direction: column;
		align-items: center;
		padding: var(--space-sm);
		cursor: pointer;
		list-style: none;
		font-weight: 900;
	}

	.card-header::-webkit-details-marker {
		display: none;
	}

	.card-icon-wrap {
		display: flex;
		flex-direction: column;
		align-items: center;
		gap: var(--space-sm);
		width: 100%;
	}

	.card-title {
		font-size: 1rem;
		font-weight: 900;
		text-transform: uppercase;
		text-align: center;
	}

	.toggle-icon {
		display: flex;
		align-items: center;
		justify-content: center;
		width: 24px;
		height: 24px;
		margin-top: var(--space-sm);
		border-radius: 50%;
		background: var(--color-gold);
		color: var(--color-white);
	}

	.toggle-bar--v {
		transform-origin: center;
		transition: opacity 0.2s ease, transform 0.2s ease;
	}

	.card[open] .toggle-bar--v {
		opacity: 0;
		transform: rotate(90deg);
	}

	.card-body {
		padding: 0 var(--space-sm) var(--space-sm);
	}

	.card-body .body-text {
		font-size: 1.125rem;
	}

	.quote-cta {
		font-family: var(--font-heading);
		font-size: 1.4875rem;
		line-height: 1.3;
		text-align: center;
		padding: 18px 20px;
		border-radius: var(--radius-md);
		border: 3px solid #000;
		background: var(--color-green-light);
		color: var(--color-green);
	}

	@media (min-width: 768px) {
		.cards {
			/* Keep all cards the same width across breakpoints */
			display: flex;
			flex-direction: column;
			align-items: stretch;
			gap: var(--space-md);
		}
	}
</style>
