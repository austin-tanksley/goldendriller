---
const services = [
	{
		icon: '/images/icons/sanitizing.png',
		title: 'Preventive Maintenance',
	},
	{
		icon: '/images/icons/inspection.png',
		title: 'Pest Inspections',
	},
	{
		icon: '/images/icons/spider.png',
		title: 'Roaches, Spiders, and Ants',
	},
	{
		icon: '/images/icons/Mosquito 1.svg',
		title: 'Mosquitoes',
	},
];
---

<section class="services" id="services">
	<div class="services-header">
		<p class="section-label">— We Do It and We Do It Well</p>
		<h2 class="section-heading">Services</h2>
	</div>

	<ul class="services-list">
		{
			services.map((service) => (
				<li class="service-item">
					<img src={service.icon} alt="" width="64" height="64" />
					<span class="service-title">{service.title}</span>
				</li>
			))
		}
	</ul>
</section>

<style>
	.services {
		padding: var(--space-xl) var(--content-inset);
		background: var(--color-cream-dark);
	}

	.services-header {
		margin-bottom: var(--space-md);
	}

	.services-list {
		list-style: none;
		margin: 0;
		padding: 0;
	}

	.service-item {
		display: flex;
		align-items: center;
		gap: var(--space-md);
		padding: var(--space-xs) 0;
		border-bottom: 2px solid rgba(27, 67, 28, 0.15);
	}

	.service-item:last-child {
		border-bottom: none;
	}

	.service-item img {
		flex-shrink: 0;
		width: 64px;
		height: 64px;
		object-fit: contain;
	}

	.service-title {
		font-size: 0.875rem;
		font-weight: 700;
		line-height: 1.3;
		letter-spacing: 0.03em;
		text-transform: uppercase;
		color: var(--color-green);
	}

	@media (min-width: 768px) {
		.services-list {
			display: grid;
			grid-template-columns: 1fr 1fr;
			column-gap: var(--space-xl);
			row-gap: var(--space-lg);
		}

		.service-item {
			border-bottom: none;
			padding: 0;
		}
	}
</style>
