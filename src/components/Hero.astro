---
---

<section class="hero">
	<div class="hero-left">
		<div class="hero-content">
			<h1 class="hero-heading">Your home. Your&nbsp;rules. Zero pests.</h1>
			<p class="hero-subtitle">
				Fair prices, straight talk, and a job we'd stake our name on.
			</p>
		</div>

		<div class="hero-actions">
			<a href="#why-us" class="btn btn-outline">Learn More</a>
			<a href="#quote" class="btn btn-primary">Grab a Quote</a>
		</div>
	</div>

	<img
		class="hero-image"
		src="/images/hero.png"
		alt="Golden Driller pest control technician treating a lawn"
		width="354"
		height="354"
	/>
</section>

<style>
	.hero {
		padding: var(--space-2xl) var(--content-inset) var(--space-xl);
		background: var(--color-white);
	}

	.hero-left {
		display: flex;
		flex-direction: column;
		gap: var(--space-xl);
		margin-bottom: var(--space-2xl);
	}

	.hero-content {
		display: flex;
		flex-direction: column;
		gap: var(--space-md);
		text-align: center;
	}

	.hero-heading {
		font-family: var(--font-heading);
		font-size: 2.5rem;
		font-weight: 800;
		line-height: 1.1;
		letter-spacing: 0.01em;
		text-transform: uppercase;
		color: var(--color-green);
		margin: 0;
	}

	.hero-subtitle {
		font-size: 1.2rem;
		line-height: 1.5;
		color: var(--color-green);
		margin: 0;
	}

	.hero-actions {
		display: flex;
		gap: var(--space-md);
	}

	.hero-actions .btn {
		flex: 1;
		white-space: nowrap;
	}

	.hero-image {
		width: 100%;
		border-radius: var(--radius-md);
		object-fit: cover;
		aspect-ratio: 1;
	}

	@media (min-width: 768px) {
		.hero {
			display: grid;
			grid-template-columns: 1fr 1fr;
			align-items: center;
			column-gap: var(--space-xl);
		}

		.hero-left {
			margin-bottom: 0;
		}

		.hero-heading {
			font-size: 2.8rem;
		}
		.hero-content {
			text-align: left;
		}

		.hero-image {
			aspect-ratio: 1 / 1;
		}
	}
</style>
