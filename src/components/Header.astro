<header class="header">
	<a href="/" class="logo">LOGO</a>
	<button class="menu-btn" type="button" aria-label="Open menu">
		<span></span>
		<span></span>
		<span></span>
	</button>
</header>

<style>
	.header {
		display: flex;
		align-items: center;
		justify-content: space-between;
		height: 80px;
		padding: 0 var(--space-lg);
		background: var(--color-white);
	}

	.logo {
		font-size: 1.5rem;
		font-weight: 800;
		letter-spacing: 0.02em;
		color: var(--color-text);
	}

	.menu-btn {
		display: flex;
		flex-direction: column;
		justify-content: center;
		gap: 6px;
		width: 48px;
		height: 48px;
		padding: 12px;
	}

	.menu-btn span {
		display: block;
		width: 100%;
		height: 2px;
		background: var(--color-text);
		border-radius: 1px;
	}
</style>
