---
const navLinks = [
	{ href: '#why-us', label: 'About' },
	{ href: '#services', label: 'Services' },
];
---

<header class="header">
	<a href="/" class="logo">
		<img src="/images/Logo.png" alt="Golden Driller Pest Control" />
	</a>

	<nav class="nav-desktop" aria-label="Primary">
		{navLinks.map((link) => <a href={link.href}>{link.label}</a>)}
		<a href="#quote" class="btn nav-quote">Get a Quote</a>
	</nav>

	<button
		class="menu-btn"
		type="button"
		aria-label="Open menu"
		aria-expanded="false"
		aria-controls="mobile-menu"
	>
		<span></span>
		<span></span>
		<span></span>
	</button>

	<div class="mobile-menu" id="mobile-menu" hidden>
		<nav class="mobile-menu__panel" aria-label="Mobile">
			{navLinks.map((link) => <a href={link.href}>{link.label}</a>)}
			<a href="#quote" class="btn nav-quote nav-quote--mobile">Get a Quote</a>
		</nav>
	</div>
</header>

<script>
	const header = document.querySelector('.header');
	const menuBtn = header?.querySelector('.menu-btn') as HTMLButtonElement | null;
	const menu = document.getElementById('mobile-menu');

	const setOpen = (open: boolean) => {
		if (!header || !menuBtn || !menu) return;
		header.classList.toggle('is-open', open);
		menuBtn.setAttribute('aria-expanded', String(open));
		menuBtn.setAttribute('aria-label', open ? 'Close menu' : 'Open menu');
		menu.hidden = !open;
		document.body.style.overflow = open ? 'hidden' : '';
	};

	menuBtn?.addEventListener('click', () => {
		setOpen(!header?.classList.contains('is-open'));
	});

	// Close when a link is chosen or the backdrop is tapped.
	menu?.addEventListener('click', (event) => {
		const target = event.target as HTMLElement;
		if (target === menu || target.closest('a')) {
			setOpen(false);
		}
	});

	document.addEventListener('keydown', (event) => {
		if (event.key === 'Escape') setOpen(false);
	});
</script>

<style>
	.header {
		position: sticky;
		top: 0;
		z-index: 50;
		display: flex;
		align-items: center;
		justify-content: space-between;
		height: 80px;
		padding: 0 var(--content-inset);
		background: var(--color-green);
	}

	.logo {
		display: flex;
		align-items: center;
	}

	.logo img {
		height: 55px;
		width: auto;
	}

	/* ---------- Desktop inline menu ---------- */
	.nav-desktop {
		display: none;
		align-items: center;
		gap: var(--space-xl);
	}

	.nav-desktop > a:not(.btn) {
		font-size: 0.9375rem;
		font-weight: 700;
		letter-spacing: 0.06em;
		text-transform: uppercase;
		color: var(--color-cream);
		transition: color 0.18s ease;
	}

	.nav-desktop > a:not(.btn):hover {
		color: var(--color-gold);
	}

	.nav-quote {
		padding: 10px 18px;
		font-size: 0.875rem;
		background: var(--color-gold);
		color: var(--color-green-dark);
		border: 3px solid var(--color-gold);
		transition: background-color 0.18s ease, border-color 0.18s ease;
	}

	.nav-quote:hover {
		background: var(--color-cream);
		border-color: var(--color-cream);
	}

	/* ---------- Hamburger ---------- */
	.menu-btn {
		display: flex;
		flex-direction: column;
		justify-content: center;
		gap: 6px;
		width: 48px;
		height: 48px;
		padding: 12px;
		border-radius: var(--radius-sm);
		z-index: 60;
	}

	.menu-btn span {
		display: block;
		width: 100%;
		height: 2px;
		background: var(--color-cream);
		border-radius: 1px;
		transition: transform 0.25s ease, opacity 0.2s ease;
	}

	.header.is-open .menu-btn span:nth-child(1) {
		transform: translateY(8px) rotate(45deg);
	}

	.header.is-open .menu-btn span:nth-child(2) {
		opacity: 0;
	}

	.header.is-open .menu-btn span:nth-child(3) {
		transform: translateY(-8px) rotate(-45deg);
	}

	/* ---------- Mobile pop-up menu ---------- */
	.mobile-menu {
		position: fixed;
		inset: 0;
		z-index: 55;
		display: flex;
		align-items: center;
		justify-content: center;
		padding: var(--space-xl);
		background: rgba(21, 51, 24, 0.6);
		backdrop-filter: blur(3px);
		animation: menu-fade 0.2s ease;
	}

	.mobile-menu[hidden] {
		display: none;
	}

	.mobile-menu__panel {
		display: flex;
		flex-direction: column;
		align-items: stretch;
		gap: var(--space-lg);
		width: min(90vw, 360px);
		padding: var(--space-2xl) var(--space-xl);
		text-align: center;
		background: var(--color-cream);
		border: 3px solid var(--color-gold);
		border-radius: var(--radius-lg);
		box-shadow: 0 24px 48px rgba(0, 0, 0, 0.35);
		animation: menu-pop 0.25s cubic-bezier(0.22, 1, 0.36, 1);
	}

	.mobile-menu__panel > a:not(.btn) {
		font-family: var(--font-heading);
		font-size: 1.5rem;
		font-weight: 800;
		letter-spacing: 0.04em;
		text-transform: uppercase;
		color: var(--color-green);
	}

	.nav-quote--mobile {
		width: 100%;
		padding: 14px 20px;
		font-size: 1rem;
	}

	@keyframes menu-fade {
		from {
			opacity: 0;
		}
		to {
			opacity: 1;
		}
	}

	@keyframes menu-pop {
		from {
			opacity: 0;
			transform: translateY(12px) scale(0.96);
		}
		to {
			opacity: 1;
			transform: translateY(0) scale(1);
		}
	}

	@media (min-width: 768px) {
		.menu-btn,
		.mobile-menu {
			display: none !important;
		}

		.nav-desktop {
			display: flex;
		}
	}
</style>
